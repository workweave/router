# Router environment template.
#
# Copy to .env.local and fill in. docker-compose loads .env.local
# automatically; `make dev` reads it via godotenv.
#
# Anything marked REQUIRED must be set for the router to boot.
# Anything else is optional with the documented default.

# --------------------------------------------------------------------
# Database (REQUIRED — set DATABASE_URL or all four POSTGRES_* vars).
# --------------------------------------------------------------------

# Full Postgres connection string. Takes precedence over POSTGRES_* below.
# DATABASE_URL=postgresql://router:router@localhost:5433/router?sslmode=disable

POSTGRES_USER=router
POSTGRES_PASSWORD=router
POSTGRES_DB=router
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_SSLMODE=require       # set to `disable` for local Docker
# POSTGRES_CONNECTION_NAME=    # Cloud SQL Auth Proxy instance name

# --------------------------------------------------------------------
# Provider API keys.
# At least one is recommended. OpenRouter is the suggested baseline —
# it unlocks the OSS-model pool the cluster scorer is trained against.
# Anthropic is special: when ANTHROPIC_API_KEY is unset, the router
# forwards client Anthropic auth headers upstream (passthrough mode).
# --------------------------------------------------------------------

# OPENROUTER_API_KEY=sk-or-v1-...
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1   # default; override for vLLM/Together/etc.

# ANTHROPIC_API_KEY=sk-ant-...

# OPENAI_API_KEY=sk-...
# OPENAI_BASE_URL=https://api.openai.com    # override for Azure OpenAI

# GOOGLE_API_KEY=...
# GOOGLE_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai

# --------------------------------------------------------------------
# Server.
# --------------------------------------------------------------------

PORT=8080

# `selfhosted` mounts the admin dashboard at /ui/* and the /admin/v1/* API.
# `managed` skips both (for SaaS deployments with a separate admin frontend).
ROUTER_DEPLOYMENT_MODE=selfhosted

# Admin dashboard password. Defaults to "admin" when unset (logs a warning).
# Set this in any deployment exposed to the internet.
# ROUTER_ADMIN_PASSWORD=change-me

# Cookie security flag for the admin dashboard. Set to `true` only when
# serving the dashboard over plain HTTP (e.g. local dev without TLS).
# ROUTER_COOKIE_INSECURE=false

# --------------------------------------------------------------------
# Routing.
# --------------------------------------------------------------------

# Pin a specific cluster artifact version (e.g. `v0.27`). Unset = use
# the version named in internal/router/cluster/artifacts/latest.
# ROUTER_CLUSTER_VERSION=

# Per-request ONNX embed timeout. Increase on slower hosts.
ROUTER_CLUSTER_EMBED_TIMEOUT_MS=200

# Feed the last user message to the embedder instead of concatenated context.
ROUTER_EMBED_LAST_USER_MESSAGE=false

# Pin a session to its first-routed model so multi-turn conversations stay
# coherent. Disable only if you want every turn re-routed independently.
ROUTER_SESSION_PIN_ENABLED=true

# Reuse routing decisions per API key for this many ms (0 = disabled).
ROUTER_STICKY_DECISION_TTL_MS=0

# Hard pins — bypass the cluster scorer entirely. Debugging only.
# ROUTER_HARD_PIN_MODEL=
# ROUTER_HARD_PIN_PROVIDER=
# ROUTER_HARD_PIN_EXPLORE=

# Semantic cache for routing decisions (optional).
# ROUTER_SEMANTIC_CACHE_ENABLED=false
# ROUTER_SEMANTIC_CACHE_BUCKET=
# ROUTER_SEMANTIC_CACHE_TTL_SEC=300

# Prism-style cache-aware planner. Decides per turn whether to stay on the
# pinned model or switch, weighing prompt-cache eviction cost against the
# cluster scorer's expected savings.

# Kill switch. When false the router falls back to first-decision-wins
# (pin lookup + scorer fallback, no EV math).
# ROUTER_PLANNER_ENABLED=true

# Minimum positive expected value (USD, over the remaining-turn horizon)
# required to evict a pinned model. Lower = more switches, higher = stickier.
# ROUTER_SWITCH_EV_THRESHOLD_USD=0.001

# Horizon used to amortize per-turn savings. Matches typical agentic-loop
# tail length; bump for long-running sessions to make switches more eager.
# ROUTER_SWITCH_EXPECTED_REMAINING_TURNS=3

# Handover summarizer (called on switch turns to bound the new model's first
# input cost). When the named provider isn't registered, the orchestrator
# falls back to handover.TrimLastN instead.
# ROUTER_HANDOVER_PROVIDER=anthropic
# ROUTER_HANDOVER_MODEL=claude-haiku-4-5
# ROUTER_HANDOVER_TIMEOUT_MS=3000

# ONNX runtime asset paths. The Docker image pre-populates these; only
# matters for `make dev` on Apple Silicon / non-default Linux setups.
# ROUTER_ONNX_ASSETS_DIR=/opt/router/assets
# ROUTER_ONNX_LIBRARY_DIR=/opt/homebrew/lib   # Apple Silicon brew default

# --------------------------------------------------------------------
# BYOK encryption.
# --------------------------------------------------------------------

# Tink AES-256-GCM keyset (JSON) used to encrypt customer-supplied upstream
# provider keys at rest. If unset, BYOK secrets are stored unencrypted and
# the router logs a WARN at startup. REQUIRED in any deployment that
# handles real customer secrets.
# Generate: tinkey create-keyset --key-template AES256_GCM --out-format json
# EXTERNAL_KEY_ENCRYPTION_KEY=

# --------------------------------------------------------------------
# Telemetry (OpenTelemetry).
# Setting OTEL_EXPORTER_OTLP_ENDPOINT enables async OTLP/HTTP span export.
# When unset, OTel is fully disabled at zero runtime cost.
# --------------------------------------------------------------------

# OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4318
# OTEL_EXPORTER_OTLP_HEADERS=Authorization=Bearer YOUR_TOKEN
# OTEL_EXPORTER_OTLP_TIMEOUT=10000
# OTEL_SERVICE_NAME=router
# OTEL_RESOURCE_ATTRIBUTES=deployment.environment=production,service.version=1.0.0

# Batch span processor tuning.
# OTEL_BSP_MAX_QUEUE_SIZE=1000
# OTEL_BSP_MAX_EXPORT_BATCH_SIZE=50
# OTEL_BSP_SCHEDULE_DELAY=500
# OTEL_EXPORT_WORKERS=2

# --------------------------------------------------------------------
# Logging / debug.
# --------------------------------------------------------------------

# slog level: debug | info | warn | error.
LOG_LEVEL=info

# Verbose proxy tracing. Off in production — these are very noisy.
# ROUTER_DEBUG_SSE_TRACE=false
# ROUTER_DEBUG_UPSTREAM_TRACE=false
# ROUTER_DEBUG_WRITER_TRACE=false

# --------------------------------------------------------------------
# CGO / build (only relevant for `make dev` on Apple Silicon).
# Pre-built static lib from https://github.com/daulet/tokenizers/releases.
# --------------------------------------------------------------------

# CGO_LDFLAGS=-L/path/to/libtokenizers
