{
  "name": "@workweave/router",
  "version": "0.2.5",
  "description": "One-command installer that points Claude Code, Codex, opencode, or pi at the Weave Router. For pi it also ships the routing extension, loaded via pi.extensions.",
  "bin": {
    "weave-router": "bin.js"
  },
  "pi": {
    "extensions": [
      "./pi-router/src/index.ts"
    ]
  },
  "files": [
    "bin.js",
    "install.sh",
    "uninstall.sh",
    "cc-statusline.sh",
    "commands/",
    "pi-router/",
    "opencode-weave/",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "prepack": "node ./scripts/copy-installer.js"
  },
  "engines": {
    "node": ">=18"
  },
  "peerDependencies": {
    "@mariozechner/pi-agent-core": "*",
    "@mariozechner/pi-ai": "*",
    "@mariozechner/pi-coding-agent": "*",
    "@mariozechner/pi-tui": "*",
    "typebox": "*"
  },
  "peerDependenciesMeta": {
    "@mariozechner/pi-agent-core": {
      "optional": true
    },
    "@mariozechner/pi-ai": {
      "optional": true
    },
    "@mariozechner/pi-coding-agent": {
      "optional": true
    },
    "@mariozechner/pi-tui": {
      "optional": true
    },
    "typebox": {
      "optional": true
    }
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/workweave/router.git",
    "directory": "install/npm"
  },
  "homepage": "https://workweave.ai",
  "license": "SEE LICENSE IN LICENSE",
  "keywords": [
    "weave",
    "router",
    "claude",
    "claude-code",
    "anthropic",
    "llm-router",
    "pi",
    "pi-package"
  ]
}
