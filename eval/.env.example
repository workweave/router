# Copy to .env (gitignored) for local runs. Modal runs read these from
# `modal.Secret.from_name(...)` instead — see modal_app.py.

# Direct Anthropic calls (always-{opus,sonnet,haiku} routers + inference.py).
ANTHROPIC_API_KEY=

# Judge ensemble (judges/gpt5.py + judges/gemini.py).
OPENAI_API_KEY=
GOOGLE_API_KEY=

# Optional: route the Gemini judge through Vertex AI instead of the AI
# Studio direct API. When EVAL_GEMINI_VERTEX=true the client picks up
# GCP application-default credentials (the same `gcp-credentials` Modal
# secret) and bills against GOOGLE_CLOUD_PROJECT. GOOGLE_API_KEY is
# ignored in this mode. GPT-5 cannot move to Vertex.
EVAL_GEMINI_VERTEX=
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_LOCATION=us-central1

# Router-under-test target. Defaults to the staging deployment; set to
# http://localhost:8080 for local dev against `wv backend` style runs.
ROUTER_BASE_URL=https://router-staging.workweave.ai

# Eval-only API key. Seed it with `wv mr seed-key -e staging-01
# --eval-allowlist --name router-eval` so the underlying installation
# has is_eval_allowlisted=true; the x-weave-disable-cluster trusted
# header is only honored for those installations.
ROUTER_EVAL_API_KEY=

# GCS results bucket prefix.
EVAL_GCS_PREFIX=gs://workweave-prod-01-models-v2-training/router-eval

# Optional: HF cache reuse (rate-limit friendly when loading benchmarks).
HF_TOKEN=
